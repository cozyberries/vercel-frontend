# Supabase Configuration
# Copy this file to .env.local and fill in your actual values

# Your Supabase project URL (found in your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public API key (found in your Supabase project settings)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key (found in your Supabase project settings)
# This is used for admin operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (should match your Supabase JWT secret)
JWT_SECRET=your-jwt-secret-here

# Redis (required). The app requires Redis to function. Use GET /api/health/redis to validate.
# After deploy, run POST /api/cache/warm to prefill cache. The Vercel daily cron calls GET /api/cache/warm.
UPSTASH_REDIS_REST_URL=your-redis-url-here
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# Vercel Cron Secret — auto-set by Vercel when crons are enabled in vercel.json.
# The daily cron calls GET /api/cache/warm with Authorization: Bearer {CRON_SECRET}.
# You do not need to set this manually; Vercel injects it automatically.
CRON_SECRET=

# Optional: Environment identifier
NODE_ENV=development
