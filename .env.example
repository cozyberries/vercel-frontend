# Razorpay (use test keys for local/dev: https://dashboard.razorpay.com/app/keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# UPI Payment (server-side only - not exposed to frontend)
UPI_ID=your-upi-id@bank              # required
UPI_PAYEE_NAME=YOUR NAME             # required
UPI_AID=your-aid-here                # optional

# VerifyNow OTP (server-only). SMS only. Two APIs: send OTP, validate OTP.
# Use the JWT auth token (same value as in the authToken header in the working curl from Message Central).
# 401 = wrong or expired token; set this to the exact JWT from your curl.
VERIFYNOW_KEY=
# Alternative env name for the same JWT:
# VERIFYNOW_AUTH_TOKEN=
VERIFYNOW_CUSTOMER_ID=
# Optional: request timeout in ms (default 8000). Increase on Pro if needed (e.g. 20000).
# VERIFYNOW_REQUEST_TIMEOUT_MS=8000
VERIFYNOW_PHONE_PLACEHOLDER_EMAIL_DOMAIN=phone.cozyburry.local

# Frontend URL (used in layout and for phone OTP callback). e.g. https://cozyberries.in or http://localhost:3000
NEXT_PUBLIC_FRONTEND_URL=

# Meta Pixel + Conversions API
# Pixel ID is public (safe to expose to browser)
NEXT_PUBLIC_META_PIXEL_ID=your-pixel-id-here
# Server-only token: Facebook Business Manager → Events Manager → your pixel → Settings → "Generate Access Token"
FACEBOOK_CONVERSIONS_API_TOKEN=REPLACE_WITH_YOUR_TOKEN_FROM_EVENTS_MANAGER
