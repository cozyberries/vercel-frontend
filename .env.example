# Razorpay (use test keys for local/dev: https://dashboard.razorpay.com/app/keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# UPI Payment (server-side only - not exposed to frontend)
UPI_ID=your-upi-id@bank              # required
UPI_PAYEE_NAME=YOUR NAME             # required
UPI_AID=your-aid-here                # optional

# VerifyNow OTP (server-only). Key = Base64 of your Message Central login password.
# Generate: node -e "console.log(Buffer.from('YOUR_MC_PASSWORD','utf8').toString('base64'))"
VERIFYNOW_CUSTOMER_ID=
VERIFYNOW_KEY=
VERIFYNOW_EMAIL=test@messagecentral.com
VERIFYNOW_PHONE_PLACEHOLDER_EMAIL_DOMAIN=phone.cozyburry.local
